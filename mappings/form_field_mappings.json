          {"label": "Date", "type": "date", "required": true},
          {"label": "PIN", "type": "text", "required": true}
        ],
        "instructions": "Authorize electronic filing of your tax return."
      }
    }
  },
  "8936": {
    "form_name": "Form 8936 - Qualified Plug-in Electric and Plug-in Electric Vehicle Credit",
    "tax_year": 2025,
    "sections": {
      "part_i_new_clean_vehicles": {
        "fields": [
          {"label": "Vehicle make and model", "type": "text", "required": true},
          {"label": "Vehicle Identification Number (VIN)", "type": "text", "required": true},
          {"label": "Date placed in service", "type": "date", "required": true},
          {"label": "Battery capacity (kWh)", "type": "number", "required": true},
          {"label": "Purchase price", "type": "currency", "required": true},
          {"label": "MSRP limit check", "type": "checkbox", "required": true},
          {"label": "Income limit check", "type": "checkbox", "required": true},
          {"label": "Credit amount", "type": "currency", "required": true}
        ],
        "instructions": "For new clean vehicles: up to $7,500 credit. Must meet battery component and critical mineral requirements."
      },
      "part_ii_new_clean_vehicles_30d": {
        "fields": [
          {"label": "Vehicle qualifying under IRC 30D", "type": "checkbox", "required": true},
          {"label": "Retail price limit (cars: $55,000; SUVs/vans/trucks: $80,000)", "type": "checkbox", "required": true}
        ],
        "instructions": "IRC 30D credit for new clean vehicles purchased from a dealer."
      },
      "part_iii_used_clean_vehicles": {
        "fields": [
          {"label": "Used vehicle year", "type": "number", "required": true},
          {"label": "Sale price", "type": "currency", "required": true},
          {"label": "Credit amount (up to $4,000)", "type": "currency", "required": true}
        ],
        "instructions": "For used clean vehicles: up to $4,000 credit. Vehicle must be 2+ years old."
      }
    }
  },
  "8812": {
    "form_name": "Schedule 8812 (Form 1040) - Credits for Child and Dependents",
    "tax_year": 2025,
    "sections": {
      "part_i_child_tax_credit": {
        "fields": [
          {"label": "Number of qualifying children under age 17", "type": "number", "required": true},
          {"label": "Child Tax Credit amount ($2,000 per child)", "type": "currency", "required": true},
          {"label": "Number of other dependents", "type": "number", "required": true},
          {"label": "Credit for Other Dependents ($500 per dependent)", "type": "currency", "required": true}
        ],
        "instructions": "Child Tax Credit: up to $2,000 per qualifying child under 17. Credit for Other Dependents: $500 for dependents who don't qualify for CTC."
      }
    }
  },
