      },
      "part_ii_long_term": {
        "fields": [
          {"line": "8", "label": "Long-term gains from Form 8949", "type": "currency", "required": false},
          {"line": "9", "label": "Collection >1 year (non-broker)", "type": "currency", "required": false},
          {"line": "10", "label": "Other long-term gains", "type": "currency", "required": false}
        ],
        "instructions": "Report long-term capital gains and losses."
      },
      "part_iii_summary": {
        "fields": [
          {"line": "16", "label": "Net capital gain or (loss)", "type": "currency", "required": true}
        ],
