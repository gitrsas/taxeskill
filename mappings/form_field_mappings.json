        "instructions": "Report your business income and cost of goods sold."
      },
      "part_iii_expenses": {
        "fields": [
          {"line": "5a", "label": "Advertising", "type": "currency", "required": false},
          {"line": "6", "label": "Car/truck expenses (or mileage)", "type": "currency", "required": false},
          {"line": "7", "label": "Commissions and fees", "type": "currency", "required": false},
          {"line": "8", "label": "Contract work (subcontractors)", "type": "currency", "required": false},
          {"line": "9", "label": "Depletion", "type": "currency", "required": false},
          {"line": "10", "label": "Depreciation and section 179", "type": "currency", "required": false},
          {"line": "11", "label": "Employee benefit programs", "type": "currency", "required": false},
          {"line": "12", "label": "Insurance (other than health)", "type": "currency", "required": false},
          {"line": "13", "label": "Interest", "type": "currency", "required": false},
          {"line": "14", "label": "Lobbying", "type": "currency", "required": false},
          {"line": "15", "label": "Legal and professional services", "type": "currency", "required": false},
          {"line": "16", "label": "Office expense", "type": "currency", "required": false},
          {"line": "17", "label": "Pension and profit-sharing plans", "type": "currency", "required": false},
          {"line": "18a", "label": "Rent/lease (vehicles)", "type": "currency", "required": false},
          {"line": "18b", "label": "Rent/lease ( machinery/equipment)", "type": "currency", "required": false},
          {"line": "18c", "label": "Rent/lease ( other property)", "type": "currency", "required": false},
          {"line": "19", "label": "Repairs and maintenance", "type": "currency", "required": false},
          {"line": "20", "label": "Supplies", "type": "currency", "required": false},
          {"line": "21", "label": "Taxes and licenses", "type": "currency", "required": false},
          {"line": "22", "label": "Travel", "type": "currency", "required": false},
          {"line": "23a", "label": "Utilities", "type": "currency", "required": false},
          {"line": "24", "label": "Wages (less employment credits)", "type": "currency", "required": false},
          {"line": "25", "label": "Other expenses", "type": "currency", "required": false},
          {"line": "26", "label": "Total expenses", "type": "currency", "required": true}
        ],
        "instructions": "List all ordinary and necessary business expenses."
      },
      "part_iv_net_profit": {
        "fields": [
          {"line": "31", "label": "Gross profit", "type": "currency", "required": true},
          {"line": "32", "label": "Other income (from Sch 1)", "type": "currency", "required": false},
          {"line": "33", "label": "Gross income", "type": "currency", "required": true},
          {"line": "34", "label": "Net profit or (loss)", "type": "currency", "required": true}
        ],
        "instructions": "This amount flows to Schedule 1, line 3, and Form 1040."
      }
    }
