{
  "1040": {
    "form_name": "U.S. Individual Income Tax Return",
    "tax_year": 2025,
    "sections": {
      "filing_status": {
        "fields": [
          {"line": "1", "label": "Single / Married Filing Jointly / Head of Household / Qualifying Surviving Spouse / Married Filing Separately", "type": "select", "required": true},
          {"line": "2", "label": "Spouse's name (if filing jointly)", "type": "text", "required": false},
          {"line": "3", "label": "SSN", "type": "ssn", "required": false}
        ],
        "instructions": "Choose your filing status. This affects your tax rate and standard deduction."
      },
      "dependents": {
        "fields": [
          {"line": "6a-6d", "label": "Dependent first name", "type": "text", "required": false},
          {"line": "6a-6d", "label": "Dependent last name", "type": "text", "required": false},
          {"line": "6a-6d", "label": "Dependent SSN", "type": "ssn", "required": false},
          {"line": "6a-6d", "label": "Dependent relationship", "type": "select", "required": false},
          {"line": "6a-6d", "label": "Dependent qualifies for Child Tax Credit", "type": "checkbox", "required": false},
          {"line": "6a-6d", "label": "Dependent qualifies for Credit for Other Dependents", "type": "checkbox", "required": false}
        ],
        "instructions": "List all dependents who lived with you for more than half the year."
      },
      "income": {
        "fields": [
          {"line": "1a-1z", "label": "Wages, salaries, tips (from W-2)", "type": "currency", "required": false},
          {"line": "2a-2b", "label": "Taxable interest", "type": "currency", "required": false},
          {"line": "3a-3b", "label": "Qualified dividends", "type": "currency", "required": false},
          {"line": "4a-4b", "label": "Capital gain or loss", "type": "currency", "required": false},
          {"line": "5a-5b", "label": "Capital gain distribution", "type": "currency", "required": false},
          {"line": "6-8", "label": "Other income", "type": "currency", "required": false},
          {"line": "9", "label": "Total income", "type": "currency", "required": true}
        ],
        "instructions": "Report all income from W-2s, 1099s, and other sources."
      },
      "adjustments": {
        "fields": [
          {"line": "11-24z", "label": "Adjustments to income (IRA deduction, student loan interest, etc.)", "type": "currency", "required": false}
        ],
        "instructions": "List deductible expenses that reduce your taxable income."
      },
      "tax": {
        "fields": [
          {"line": "15", "label": "Tax (from tax tables or rate schedules)", "type": "currency", "required": true},
          {"line": "16", "label": "Additional tax (AMT, etc.)", "type": "currency", "required": false},
          {"line": "17", "label": "Total tax", "type": "currency", "required": true}
        ],
        "instructions": "Calculated based on your taxable income and filing status."
      },
      "payments": {
        "fields": [
          {"line": "24-28", "label": "Federal income tax withheld (from W-2s and 1099s)", "type": "currency", "required": false},
          {"line": "25", "label": "2024 estimated tax payments", "type": "currency", "required": false},
          {"line": "27", "label": "Earned income credit", "type": "currency", "required": false},
          {"line": "28", "label": "Additional child tax credit", "type": "currency", "required": false},
          {"line": "30", "label": "Total payments", "type": "currency", "required": true}
        ],
        "instructions": "Sum of all taxes already paid through withholding and estimated payments."
      },
      "refund_owed": {
        "fields": [
          {"line": "31", "label": "Amount you overpaid", "type": "currency", "required": false},
          {"line": "32", "label": "Amount you owe", "type": "currency", "required": false},
          {"line": "33", "label": "Refund", "type": "currency", "required": false},
          {"line": "34", "label": "Refund applied to 2025 estimated tax", "type": "currency", "required": false},
          {"line": "35", "label": "Total paid", "type": "currency", "required": false}
        ],
        "instructions": "If overpaid, you get a refund. If underpaid, you owe the difference."
      }
    }
  },
  "schedule_1": {
    "form_name": "Schedule 1 (Form 1040) - Additional Income and Adjustments",
    "tax_year": 2025,
    "sections": {
      "part_i_additional_income": {
        "fields": [
          {"line": "1", "label": "Taxable refunds (state/local income tax)", "type": "currency", "required": false},
          {"line": "2", "label": "Taxable grants", "type": "currency", "required": false},
          {"line": "3", "label": "Alien status change", "type": "text", "required": false},
          {"line": "8", "label": "Housing exclusion/deduction (Form 2555)", "type": "currency", "required": false},
          {"line": "9", "label": "Jury pay (with offset to employer)", "type": "currency", "required": false},
          {"line": "10", "label": "Other income (describe)", "type": "text", "required": false}
        ],
        "instructions": "Report income not included on lines 1-9 of Form 1040."
      },
      "part_ii_adjustments": {
        "fields": [
          {"line": "12", "label": "Educator expenses", "type": "currency", "required": false},
          {"line": "13", "label": "IRA deduction", "type": "currency", "required": false},
          {"line": "14", "label": "Student loan interest", "type": "currency", "required": false},
          {"line": "15", "label": "Self-employment tax", "type": "currency", "required": false},
          {"line": "16", "label": "Self-employed SEP/SIMPLE/qualified plan", "type": "currency", "required": false},
          {"line": "17", "label": "Self-employed health insurance", "type": "currency", "required": false},
          {"line": "18", "label": "Penalty on early withdrawal", "type": "currency", "required": false},
          {"line": "20", "label": "Health savings account deduction (Form 8889)", "type": "currency", "required": false},
          {"line": "21", "label": "Tuition and fees (deprecated)", "type": "currency", "required": false},
          {"line": "24z", "label": "Total adjustments", "type": "currency", "required": true}
        ],
        "instructions": "Deductions that reduce your adjusted gross income (AGI)."
      }
    }
  },
  "schedule_a": {
    "form_name": "Schedule A (Form 1040) - Itemized Deductions",
    "tax_year": 2025,
    "sections": {
      "part_i_medical": {
        "fields": [
          {"line": "1", "label": "Medical expenses paid", "type": "currency", "required": false},
          {"line": "2a", "label": "Form 1040 line 11 (AGI)", "type": "currency", "required": false},
          {"line": "2b", "label": "7.5% of AGI", "type": "currency", "required": true},
          {"line": "3", "label": "Subtract line 2b from line 1", "type": "currency", "required": true}
        ],
        "instructions": "Deduct medical expenses exceeding 7.5% of your AGI."
      },
      "part_ii_interest": {
        "fields": [
          {"line": "5a", "label": "Home mortgage interest (bank)", "type": "currency", "required": false},
          {"line": "5b", "label": "Home mortgage interest (points)", "type": "currency", "required": false},
          {"line": "5c", "label": "Mortgage insurance premiums", "type": "currency", "required": false},
          {"line": "6", "label": "Investment interest", "type": "currency", "required": false},
          {"line": "7", "label": "Total interest", "type": "currency", "required": true}
        ],
        "instructions": "Deduct home mortgage interest, points, and investment interest."
      },
      "part_iii_taxes": {
        "fields": [
          {"line": "8", "label": "State and local income taxes", "type": "currency", "required": false},
          {"line": "9", "label": "Real estate taxes", "type": "currency", "required": false},
          {"line": "10", "label": "Personal property taxes", "type": "currency", "required": false},
          {"line": "11", "label": "Total SALT (capped at $10,000)", "type": "currency", "required": true}
        ],
        "instructions": "State and local taxes are capped at $10,000 combined."
      },
      "part_iv_charitable": {
        "fields": [
          {"line": "13", "label": "Cash contributions", "type": "currency", "required": false},
          {"line": "14", "label": "Non-cash contributions", "type": "currency", "required": false},
          {"line": "15", "label": "Other charitable contributions", "type": "currency", "required": false},
          {"line": "16", "label": "Total charitable contributions", "type": "currency", "required": true}
        ],
        "instructions": "Deduct charitable donations to qualified organizations."
      },
      "part_v_other": {
        "fields": [
          {"line": "17", "label": "Total itemized deductions", "type": "currency", "required": true}
        ],
        "instructions": "Compare to your standard deduction. Itemize if this total is higher."
      }
    }
  },
  "schedule_c": {
    "form_name": "Schedule C (Form 1040) - Profit or Loss from Business",
